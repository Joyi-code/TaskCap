{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "TaskCap",
  "version": "0.1.1",
  "identifier": "io.taskcap.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://127.0.0.1:5181",
    "beforeDevCommand": "powershell -ExecutionPolicy Bypass -File scripts/dev.ps1",
    "beforeBuildCommand": "powershell -ExecutionPolicy Bypass -File scripts/build.ps1"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "installerHooks": "windows/installer-hooks.nsh"
      }
    }
  }
}
